---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="Contact | Saad Boukhrouf"
  description="Contact Saad Boukhrouf for collaborations around AI, smart cities, urban innovation, remote sensing, and territorial resilience."
>
  <section class="section page">
    <p class="eyebrow">Contact</p>
    <h1>Let’s discuss cities, data, and resilient development.</h1>
    <p class="lead">
      Open to professional conversations, research collaborations, and projects
      involving AI, smart cities, remote sensing, and territorial innovation.
    </p>
  </section>

  <section class="band">
    <div class="section contact-panel">
      <article class="card">
        <h2>Email</h2>
        <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
      </article>
      <article class="card">
        <h2>Location</h2>
        <p>{site.location}</p>
      </article>
    </div>
  </section>
</BaseLayout>
