---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="section hero">
    <figure class="hero-portrait" aria-label="Portrait of Saad Boukhrouf">
      <img src="/profile.jpg" alt="Saad Boukhrouf" width="768" height="1024" />
    </figure>
    <div class="hero-copy">
      <p class="eyebrow">Engineer · AI · Urban innovation · Morocco</p>
      <h1>Saad Boukhrouf</h1>
      <p class="lead">
        Engineer interested in AI, smart cities, territorial governance, remote sensing,
        and resilient urban development in Morocco.
      </p>
      <div class="actions">
        <a class="button" href="/projects/">View projects</a>
        <a class="button secondary" href="/contact/">Contact</a>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Focus</p>
          <h2>Research-minded engineering for cities and territories.</h2>
        </div>
        <p>
          Work at the intersection of geospatial evidence, public decision-making,
          and digital systems for more resilient urban development.
        </p>
      </div>
      <div class="grid">
        <article class="card">
          <h3>AI & Urban Analytics</h3>
          <p>Applied data methods for understanding growth, risk, service gaps, and urban dynamics.</p>
        </article>
        <article class="card">
          <h3>Smart Cities</h3>
          <p>Practical digital tools that support governance, infrastructure, and local services.</p>
        </article>
        <article class="card">
          <h3>Remote Sensing</h3>
          <p>Satellite and geospatial analysis for monitoring territorial change and resilience.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="section grid two">
      <div>
        <p class="eyebrow">Profile</p>
        <h2>Built for clarity, speed, and serious professional presence.</h2>
      </div>
      <div class="prose">
        <p>
          This portfolio presents projects, writing, and professional background around
          AI-enabled territorial intelligence, smart city strategy, and resilient urban
          development in Morocco.
        </p>
        <p>
          The site is static, lightweight, SEO-ready, and deployable directly to Netlify.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
